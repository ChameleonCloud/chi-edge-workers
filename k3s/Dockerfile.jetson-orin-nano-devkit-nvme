FROM ghcr.io/chameleoncloud/chi-edge-workers/jetson-base:t234-r36.4

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
    iproute2 \
    runc \
    && rm -rf /var/lib/apt/lists/*

# Tegra requires CSV runtime mode; "auto" tries CDI which fails
# with "unsupported device id: tegra".
COPY nvidia-container-runtime.toml /etc/nvidia-container-runtime/config.toml

ARG K3S_VERSION=v1.29.15%2Bk3s1

COPY install-k3s.sh /docker/install-k3s.sh
RUN /docker/install-k3s.sh "aarch64"

ENV UDEV=on

COPY start.sh /docker/start.sh
CMD ["/docker/start.sh", "--default-runtime=nvidia"]
